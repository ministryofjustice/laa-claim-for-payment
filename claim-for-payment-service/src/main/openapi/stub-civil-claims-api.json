          },
          "client": {
            "type": "string",
            "description": "client name"
          },
          "category": {
            "type": "string",
            "description": "claim category"
          },
          "concluded": {
            "type": "string",
            "format": "date",
            "description": "claim concluded date"
          },
          "feeType": {
            "type": "string",
            "description": "fee type"
          },
          "escaped": {
            "type": "boolean",
            "description": "escaped status"
          },
          "counselPayment": {
            "type": "string",
            "description": "status of counsel payment"
          },
          "claimed": {
            "type": "number",
            "description": "amount claimed"
          },
          "submissionId": {
            "type": "string",
            "format": "uuid",
            "description": "id of the submission this claim links to"
          }
        },
        "required": [
          "client",
          "ufn"
        ]
      },
      "CreateClaimResponse": {
        "type": "object",
