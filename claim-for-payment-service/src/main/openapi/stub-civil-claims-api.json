      "get": {
        "tags": [
          "Claims"
        ],
        "summary": "Get a claim by ID",
        "operationId": "getClaim",
        "parameters": [
          {
            "name": "claimId",
            "in": "path",
            "description": "ID of the claim to retrieve",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "403": {
            "description": "Forbidden"
