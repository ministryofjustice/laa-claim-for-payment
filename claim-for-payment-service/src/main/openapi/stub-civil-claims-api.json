            "type": "integer",
            "format": "int64"
          }
        },
        "required": [
          "id"
        ]
      },
      "ClaimPageResponse": {
        "type": "object",
        "description": "Paged list of claims",
        "properties": {
          "claims": {
            "type": "array",
            "description": "Claims in this page",
            "items": {
              "$ref": "#/components/schemas/Claim"
            }
          },
          "page": {
            "type": "integer",
            "format": "int32",
            "description": "Current page index"
          },
          "limit": {
            "type": "integer",
            "format": "int32",
            "description": "Maximum number of claims per page"
          },
          "total": {
            "type": "integer",
            "format": "int64",
            "description": "Total number of claims across all pages"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32",
            "description": "Total number of pages available"
          }
        }
