              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "403": {
            "description": "Forbidden"
          },
          "204": {
            "description": "Claim deleted successfully"
          },
          "404": {
            "description": "Claim not found"
          }
        }
      }
    }
